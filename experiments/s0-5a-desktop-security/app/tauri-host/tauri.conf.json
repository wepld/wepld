{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "s05a-desktop-security",
  "version": "0.0.1",
  "identifier": "dev.wepld.experiments.s05a",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "S0.5A Desktop Security Prototype — EXPERIMENTAL",
        "width": 820,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; object-src 'none'",
      "dangerousDisableAssetCspModification": false,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
